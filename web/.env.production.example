# ⚠️ Ceci est un EXEMPLE, versionné dans un repo public.
# NE METTEZ JAMAIS de vraies valeurs ici. Copiez ce fichier en `.env.production`
# (ignoré par git) sur le serveur et remplissez-y les secrets réels.

# Container timezone (also forced by docker-compose, kept here for clarity).
# Should match n8n / your sheet / your bot so dates align.
TZ=Europe/Paris

# Users live in the SQLite DB (data/app.db).
# These two vars are ONLY used the first time the DB is created — to bootstrap
# the very first admin account. Once at least one user exists, they are ignored.
# (After the first launch the bootstrap user is automatically promoted to super_admin.)
BOOTSTRAP_ADMIN_USERNAME=changeme
BOOTSTRAP_ADMIN_PASSWORD=changeme

# Optional: where to store the SQLite DB. Defaults to ./data/app.db.
# In Docker we mount a volume on /app/data and set DATABASE_PATH=/app/data/app.db
# DATABASE_PATH=

# Secret used to sign session cookies. Different from N8N_API_KEY.
# Générez une valeur unique avec :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=REMPLACER_PAR_UN_SECRET_ALEATOIRE_32_OCTETS_HEX

# n8n production webhook base URL (no trailing slash, no -test).
N8N_WEBHOOK_BASE=https://n8n.example.com/webhook

# Shared secret sent in X-API-Key header to n8n. Must match the value
# checked by the IF nodes in your n8n workflows.
# Générez une valeur unique (même commande que AUTH_SECRET).
N8N_API_KEY=REMPLACER_PAR_UN_SECRET_ALEATOIRE_32_OCTETS_HEX

# URL publique du site (utilisée pour générer les URLs des pièces jointes
# que n8n et le bot vont fetch). Sans cette variable, le site génère des URLs
# avec son hostname interne (ex. http://0.0.0.0:4000), illisibles depuis
# l'extérieur.
# IMPORTANT en prod derrière un reverse proxy → mettre la vraie URL externe.
SITE_BASE_URL=https://whatsapp.example.com

# (Optionnel) Endpoint /health du bot wppconnect, joignable depuis le container
# du site. S'il est renseigné, un bandeau d'alerte s'affiche dans l'app quand le
# bot est déconnecté (session WhatsApp à re-scanner). Laissé vide → désactivé.
# Ex : http://192.168.1.50:3000/health  ou  http://bot:3000/health
# BOT_HEALTH_URL=
